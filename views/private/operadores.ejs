<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Operadores</title>
    <link rel="stylesheet" href="/css/estilos.css">
</head>
<body>
    <h1>Lista de Operadores</h1>
    <!-- Enlace para volver al menú principal -->
    <a href="/">Volver al menú principal</a>

        <h2>Agregar operador</h2>
    <form action="/operadores/agregar" method="POST">
        <input type="text" name="nombre" placeholder="Nombre" required>
        <input type="text" name="apellido" placeholder="Apellido" required>
        <input type="text" name="telefono" placeholder="Telefono">
        <select name="tipo_servicio" required>
            <option value="mototaxi">Mototaxi</option>
            <option value="bicitaxi">Bicitaxi</option>
        </select>
        <select name="estado" required>
            <option value="activo">Activo</option>
            <option value="inactivo">Inactivo</option>
        </select>
        <button type="submit">Agregar operador</button>
    </form>
    <br>

    <table border="1">
        <thead>
            <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th>Apellido</th>
                <th>Telefono</th>
                <th>Servicio</th>
                <th>Estado</th>
            </tr>
        </thead>
        <tbody>
            <% operadores.forEach((operador) => { %>
                <tr>
                    <td><%= operador.id_operador %></td>
                    <td><%= operador.nombre %></td>
                    <td><%= operador.apellido %></td>
                    <td><%= operador.telefono %></td>
                    <td><%= operador.tipo_servicio %></td>
                    <td><%= operador.estado %></td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</body>
</html>